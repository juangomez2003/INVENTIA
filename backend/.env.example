# =====================================================
# INVENTIA BACKEND - Variables de Entorno
# =====================================================
# Copia este archivo como .env y completa los valores:
#   cp .env.example .env

# Firebase Admin SDK
# Descarga el JSON desde: Firebase Console > Configuración del proyecto
#   > Cuentas de servicio > Generar nueva clave privada
FIREBASE_TYPE=service_account
FIREBASE_PROJECT_ID=tu-project-id
FIREBASE_PRIVATE_KEY_ID=tu-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\ntu-clave\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-project-id.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=123456789
FIREBASE_AUTH_URI=https://accounts.google.com/o/oauth2/auth
FIREBASE_TOKEN_URI=https://oauth2.googleapis.com/token
FIREBASE_AUTH_PROVIDER_CERT_URL=https://www.googleapis.com/oauth2/v1/certs
FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk

# App
# ── Stripe ────────────────────────────────────
# Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

APP_ENV=development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
SECRET_KEY=cambia-esto-en-produccion

# Supabase Admin
# Dashboard -> Settings -> API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key
SUPABASE_JWT_SECRET=tu-jwt-secret
